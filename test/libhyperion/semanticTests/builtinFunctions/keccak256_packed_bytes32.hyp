contract C {
    function single(bytes32 label) public returns (bytes32) {
        return keccak256(abi.encodePacked(label));
    }

    function pair(bytes32 node, bytes32 label) public returns (bytes32) {
        return keccak256(abi.encodePacked(node, label));
    }
}
