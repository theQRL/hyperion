contract C {
	function l(uint8 y) public returns (bytes64) {
		bytes64 x;
		assembly { x := "12345678901234567890abcde" }
		// When compiling via IR, `x` is truncated before applying
		// the operation.
		return x << y;
	}
	function r(uint8 y) public returns (bytes64) {
		bytes64 x;
		assembly { x := "12345678901234567890abcde" }
		return x >> y;
	}
}
// ====
// compileViaYul: false
// ----
// l(uint8): 64 -> 0x313233343536373839303132333435363738393061626364650000000000000000
// r(uint8): 64 -> 0x3132333435363738393031323334353637
