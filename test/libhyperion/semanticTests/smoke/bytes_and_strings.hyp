contract C {
    function e(bytes memory b) public pure returns (bytes memory) {
        return b;
    }
    function f() public pure returns (string memory, string memory) {
        return ("any", "any");
    }
    function g() public pure returns (string memory, uint, string memory) {
        return ("any", 42, "any");
    }
    function h() public pure returns (string memory) {
        return "any";
    }
}
// ----
// e(bytes): 32, 3, hex"AB33BB" -> FAILURE, hex"4e487b71", 0x41
// e(bytes): 32, 32, 0x20 -> FAILURE, hex"4e487b71", 0x41
// e(bytes): 32, 3, hex"AB33FF" -> FAILURE, hex"4e487b71", 0x41
// f() -> 0x80, 0x0100, 3, "any", 3, "any"
// g() -> 0xc0, 0x2a, 0x0140, 3, "any", 3, "any"
// h() -> 0x40, 3, "any"
