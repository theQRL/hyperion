pragma abicoder               v2;

contract C {
    function f(uint256[3] calldata s1, uint256[2] calldata s2, bool which) external pure returns (bytes memory) {
        if (which)
            return abi.encode(s1);
        else
            return abi.encode(s2);
    }
    function g(uint256[3] calldata s1, uint256[2] calldata s2, bool which) external view returns (bytes memory) {
        return this.f(s1, s2, which);
    }
}
// ----
// f(uint256[3],uint256[2],bool): 23, 42, 87, 51, 72, true -> 0x40, 0xc0, 0x17, 0x2a, 0x57
// f(uint256[3],uint256[2],bool): 23, 42, 87, 51, 72, false -> 0x40, 0x80, 0x33, 0x48
// g(uint256[3],uint256[2],bool): 23, 42, 87, 51, 72, true -> 0x40, 0xc0, 0x17, 0x2a, 0x57
// g(uint256[3],uint256[2],bool): 23, 42, 87, 51, 72, false -> 0x40, 0x80, 0x33, 0x48
