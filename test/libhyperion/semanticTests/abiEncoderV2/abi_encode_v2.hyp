// f4() -> 0x40, 0x02c0, 1, 0x0100, 0x0180, 2, 3, 5100430858523435259721413331569694807054408280462178026142500737388773216944382188967371541643175456001242389359996876570687300089053293933520314668417024, 7, 0x80, 2, 2, 3
