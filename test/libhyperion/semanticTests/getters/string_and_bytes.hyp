contract C {
    string public a;
    string public b;
    bytes public c;
    string public d = "abcd";
    constructor() {
        a = "hello world";
        b = hex"41424344";
        c = hex"ff077fff";
    }
}
// ----
// a() -> 0x40, 11, "hello world"
// b() -> 0x40, 4, "ABCD"
// c() -> 0x40, 4, -50839851000635503734634583860450879126031027526204492676633519919900037650781840500296408741742802004241679972683098474268528411176258190147794000412672
// d() -> 0x40, 4, "abcd"
