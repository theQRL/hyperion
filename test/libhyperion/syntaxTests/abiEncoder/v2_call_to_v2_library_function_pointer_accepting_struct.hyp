pragma abicoder               v2;

import "A";

contract Test {
    function foo() public {
        // NOTE: This test checks a case that is currently not possible (pointer to an external
        // library function) but it might become possible in the future.
        function(L.Item memory) external ptr = L.get;
        ptr(L.Item(5));
    }
}
