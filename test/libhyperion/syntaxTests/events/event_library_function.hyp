library L {
	function f() public {
		int x = 1;
	}
}

contract C {
	event Test(function() external indexed);

	function g() public {
		Test(L.f);
	}
}

contract D {
	event Test(function() external);

	function f() public {
		Test(L.f);
	}
}

contract E {
	event Test(function() external indexed);

	using L for D;

	function k() public {
		Test(D.f);
	}
}
